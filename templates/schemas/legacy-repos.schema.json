{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/raintr91/platform-dna/blob/main/templates/schemas/legacy-repos.schema.json",
  "title": "Portable legacy evidence repository map",
  "type": "object",
  "required": ["projects"],
  "properties": {
    "projects": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "root": { "const": "." },
          "write": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
