{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/raintr91/platform-dna/blob/main/templates/schemas/platform-repos.schema.json",
  "title": "Portable platform repository map",
  "type": "object",
  "required": ["defaultGroup", "harness", "groups", "projects"],
  "properties": {
    "defaultGroup": { "enum": ["docs", "fe", "be", "tests", "tooling"] },
    "harness": {
      "type": "object",
      "required": ["profiles"],
      "properties": {
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["groups", "skills"],
            "properties": {
              "groups": { "type": "array", "items": { "type": "string" } },
              "skills": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "groups": { "type": "object" },
    "projects": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["root", "role", "repo", "write"],
        "properties": {
          "root": { "const": "." },
          "role": { "enum": ["docs", "fe", "be", "tests", "tooling"] },
          "repo": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "write": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
